# Database
POSTGRES_DB=redteam
POSTGRES_USER=redteam
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5433
DATABASE_URL=postgresql://redteam:change_me@localhost:5433/redteam

# Session HMAC signing key & encryption keys (generate with: openssl rand -hex 32)
SESSION_SECRET=dev-session-secret-change-in-production-minimum-32-chars
TOTP_PENDING_KEY=dacd392bd003d2a122333728fb37816b68ac4648a3ad7ffa5d98c5e7dd6bfb0c
RESOURCE_MASTER_KEY=f7475ecdf6600eb8b8310cbb067d846a4e7a56ab6547ace4e541aefe0ac3acb6

# Registration: "open" (anyone can register), "code" (requires security code), "disabled" (no registration)
REGISTRATION_MODE=open
# Required when REGISTRATION_MODE=code
# REGISTRATION_CODE=

# CAPTCHA (Captchacat) - Disabled by default for development
CAPTCHA_ENABLED=false
CAPTCHACAT_SITE_KEY=
CAPTCHACAT_API_KEY=

# Upload limits
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=2048
